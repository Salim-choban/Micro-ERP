<?xml version="1.0" encoding="utf-8"?>
<odoo>

   
    <record id="view_erp_product_list" model="ir.ui.view">
        <field name="name">erp.product.list</field>
        <field name="model">erp.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_type"/>
                <field name="price"/>
                <field name="qty_available"/>
            </list>
        </field>
    </record>

    
    <record id="view_erp_product_form" model="ir.ui.view">
        <field name="name">erp.product.form</field>
        <field name="model">erp.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_type"/>
                        <field name="price"/>
                        <field name="qty_available"/>
                        <field name="supplier_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_erp_product_form" model="ir.ui.view">
        <field name="name">erp.product.form</field>
        <field name="model">erp.product</field>
        <field name="arch" type="xml">
          <form>
             <sheet>
                 <field name="image_1920" widget="image" class="oe_avatar"/>
                 <div class="oe_title">
                     <label for="name" string="Product Name"/>
                     <h1><field name="name" placeholder="e.g. Kids Coloring Book"/> </h1>
                 </div>
                 <group>
                   <group>
                      <field name="default_code"/> 
                      <field name="product_type"/> 
                   </group>
                   <group>
                       <field name="price"/>
                       <field name="standard_price"/> 
                       <field name="qty_available"/>
                       <field name="supplier_id"/>
                   </group>
                 </group>
                 <notebook>
                     <page string="Description">
                         <field name="description"/> </page>
                 </notebook>
             </sheet>
          </form>
        </field>  
    </record>

    <record id="action_erp_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">erp.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_erp_product"
              name="Products"
              parent="menu_erp_root"
              action="action_erp_product"/>
</odoo>