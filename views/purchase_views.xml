<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_erp_purchase_order_list" model="ir.ui.view">
        <field name="name">erp.purchase.order.list</field>
        <field name="model">erp.purchase.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="amount_total"/>
            </list>
        </field>
    </record>

    <record id="view_erp_purchase_order_form" model="ir.ui.view">
        <field name="name">erp.purchase.order.form</field>
        <field name="model">erp.purchase.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_done"
                            string="Done"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe.title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="partner_id"/>
                    </group>
                    <notebook>
                         <page string="products">
                             <field name="order_line">
                                  <list editable="bottom">
                                       <field name="product_id"/>
                                       <field name="quantity"/>
                                       <field name="price_unit"/>
                                       <field name="price_subtotal"/>
                                  </list>
                             </field>
                         </page>
                    </notebook>
                    <group class="oe_subtotal_footer oe_right">
                        <field name="amount_total" class="oe_subtotal_footer_separator"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
   
    <record id="action_erp_purchase_order" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">erp.purchase.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_erp_purchase"
              name="Purchases"
              parent="menu_erp_root"
              sequence="30"/>
    <menuitem id="menu_erp_purchase_orders"
              name="Purchases"
              parent="menu_erp_purchase"
              action="action_erp_purchase_order"/>

</odoo>