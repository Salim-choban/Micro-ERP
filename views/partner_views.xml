<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_erp_partner_tree" model="ir.ui.view">
        <field name="name">erp.partner.list</field>
        <field name="model">erp.partner</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone"/>
                <field name="partner_type"/>
            </list>
        </field>
    </record>

   
    <record id="view_erp_partner_form" model="ir.ui.view">
        <field name="name">erp.partner.form</field>
        <field name="model">erp.partner</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_type"/>
                        <field name="phone"/>
                        <field name="address"/>
                        <field name="date_registered"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

   
    <record id="action_erp_partner" model="ir.actions.act_window">
        <field name="name">Partners</field>
        <field name="res_model">erp.partner</field>
        <field name="view_mode">list,form</field>
    </record>

   
    <menuitem id="menu_erp_root" name="Micro-ERP" sequence="1"/>

    <menuitem id="menu_erp_partner"
              name="Partners"
              parent="menu_erp_root"
              action="action_erp_partner"/>
</odoo>